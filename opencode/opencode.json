{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "grafana": {
      "type": "local",
      "command": [
        "podman",
        "run",
        "--rm",
        "-i",
        "--network=host",
        "-e",
        "GRAFANA_URL=http://localhost:3000",
        "-e",
        "GRAFANA_USERNAME=admin",
        "-e",
        "GRAFANA_PASSWORD=workshop-grafana-admin",
        "docker.io/mcp/grafana:latest",
        "-t",
        "stdio"
      ],
      "enabled": true
    }
  }
}
