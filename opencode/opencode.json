{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "mock-user-svc": {
      "type": "local",
      "command": ["node", "--enable-source-maps", "../mcp-user-svc/dist/index.js"],
      "enabled": true,
      "environment": {
        "USER_SVC_URL": "http://localhost:8082"
      }
    },
    "grafana": {
      "type": "local",
      "command": [
        "podman",
        "run",
        "--rm",
        "-i",
        "--network=host",
        "-e",
        "GRAFANA_URL=http://localhost:3000",
        "-e",
        "GRAFANA_USERNAME=admin",
        "-e",
        "GRAFANA_PASSWORD=workshop-grafana-admin",
        "docker.io/mcp/grafana:latest",
        "-t",
        "stdio"
      ],
      "enabled": true
    }
  }
}
