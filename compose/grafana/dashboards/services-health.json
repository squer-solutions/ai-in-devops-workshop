{
  "title": "Services Health",
  "uid": "services-health",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "CPU (% by container)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "system_cpu_utilization", "refId": "A" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Memory (MB)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "system_memory_usage / 1024 / 1024", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Redis queue depth (claims:queue)",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count_over_time({service=\"claims-worker\"} |~ \"processed\" [1m])",
          "refId": "A"
        }
      ]
    }
  ]
}
