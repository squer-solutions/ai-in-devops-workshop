# GitHub (used by Slot 2 MCP)
# Create a classic or fine-grained PAT with `repo` and `project` scopes.
# Then: export GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_TOKEN=

# cortecs.ai endpoint for OpenCode (reference; OpenCode has its own config)
CORTECS_API_KEY=
CORTECS_BASE_URL=https://api.cortecs.ai/v1

# Grafana (for mcp-grafana MCP)
GRAFANA_URL=http://localhost:3000
GRAFANA_SERVICE_ACCOUNT_TOKEN=

# Workshop GitHub target (used by slot2 lookup-ids helper)
GITHUB_REPO=squer-solutions/ai-in-devops-workshop
GITHUB_PROJECT_NUMBER=9
GITHUB_PROJECT_OWNER=squer-solutions
